# Instagram admin dashboard — Run Control (manual Play)
#
# Play is enabled by default on the dashboard host.
# Set INSTAGRAM_RUN_CONTROL_PLAY_ENABLED=false only for maintenance windows.
# INSTAGRAM_RUN_CONTROL_PLAY_ENABLED=false
#
# Must match RUN_CONTROL_DISPATCHER_WORKER_ID on account_run_request_consumer.py
INSTAGRAM_RUN_CONTROL_DISPATCHER_WORKER_ID=run-dispatcher:your-worker-host
#
# Optional alias accepted by the dashboard if the Instagram-prefixed var is unset:
# RUN_CONTROL_DISPATCHER_WORKER_ID=run-dispatcher:your-worker-host
#
# Dispatcher heartbeat freshness threshold in seconds (default: 60)
# INSTAGRAM_RUN_CONTROL_DISPATCHER_HEALTH_MAX_AGE_SECONDS=60
